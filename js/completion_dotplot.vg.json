{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 300,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/completion_by_state.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "red",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {"datum": 100}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 100,
        "opacity": 0.9
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "completion",
            "op": "mean",
            "order": "descending"
          },
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "completion",
          "type": "quantitative",
          "title": "Completion Rate (%)",
          "scale": {"domain": [85, 110]},
          "axis": {"format": ".1f", "labelFontSize": 11}
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "title": "Education Level",
          "scale": {
            "domain": ["Primary", "Secondary Lower", "Secondary Upper"],
            "range": ["#fbe29d", "#c1dbe8", "#6a4a3a"]
          },
          "legend": {
            "title": "Education Level",
            "orient": "bottom"
          }
        },
        "shape": {
          "field": "stage",
          "type": "nominal",
          "scale": {
            "domain": ["Primary", "Secondary Lower", "Secondary Upper"],
            "range": ["circle", "square", "triangle"]
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "stage", "type": "nominal", "title": "Level"},
          {
            "field": "completion",
            "type": "quantitative",
            "title": "Completion Rate (%)",
            "format": ".1f"
          }
        ]
      }
    },
        {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": -90,
        "dy": -20,
        "fontSize": 10,
        "color": "#fabbc9"
      },
      "encoding": {
        "x": {"datum": 100},
        "y": {"datum": 0},
        "text": {
          "value": "Above 100% reflects cross-district enrolment"
            }
          }
        }

  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"grid": true, "gridColor": "#f0f0f0"}
  }
}
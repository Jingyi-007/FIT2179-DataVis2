{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 350,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/schools_donut.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 80,
        "outerRadius": 150,
        "stroke": "white",
        "strokeWidth": 2
      },
      "encoding": {
        "theta": {
          "field": "schools",
          "type": "quantitative",
          "stack": true
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "title": "Education Level",
          "scale": {
            "domain": ["Primary", "Secondary", "Tertiary"],
            "range": ["#1a3a5c", "#e05c2a", "#2ecc71"]
          },
          "legend": {
            "title": "Education Level",
            "orient": "bottom"
          }
        },
        "tooltip": [
          {"field": "stage", "type": "nominal", "title": "Level"},
          {"field": "schools", "type": "quantitative", "title": "No. of Schools"},
          {"field": "percentage", "type": "quantitative",
           "title": "Percentage (%)", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 120,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "white"
      },
      "encoding": {
        "theta": {
          "field": "schools",
          "type": "quantitative",
          "stack": true
        },
        "text": {
          "field": "percentage",
          "type": "quantitative",
          "format": ".1f"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 0,
        "fontSize": 16,
        "fontWeight": "bold",
        "color": "#1a3a5c",
        "dy": -10
      },
      "encoding": {
        "text": {"value": "10,250"}
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 0,
        "fontSize": 11,
        "color": "#888",
        "dy": 10
      },
      "encoding": {
        "text": {"value": "Total Schools"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}
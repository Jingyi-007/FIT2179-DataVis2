{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 450,
  "height": 350,
  "padding": 5,
  "title": {
    "text": "Primary Schools by State (2022)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "data": [
    {
      "name": "tree",
      "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/schools_primary.csv",
      "format": {"type": "csv", "parse": {"schools": "number"}},
      "transform": [
        {
          "type": "treemap",
          "field": "schools",
          "sort": {"field": "schools", "order": "descending"},
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "tree", "field": "state"},
      "range": [
        "#1a3a5c","#2d6a9f","#3a86c8","#5fa8d3",
        "#85c1e9","#aed6f1","#154360","#1b4f72",
        "#2980b9","#1f618d","#7fb3d3","#21618c",
        "#2874a6","#5dade2","#a9cce3","#d4e6f1"
      ]
    }
  ],
  "marks": [
    {
      "type": "rect",
      "from": {"data": "tree"},
      "encode": {
        "enter": {
          "stroke": {"value": "white"},
          "strokeWidth": {"value": 1.5}
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "state"},
          "tooltip": {
            "signal": "{'State': datum.state, 'Primary Schools': datum.schools}"
          }
        },
        "hover": {
          "strokeWidth": {"value": 3},
          "stroke": {"value": "#333"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "tree"},
      "encode": {
        "enter": {
          "font": {"value": "Arial"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fill": {"value": "white"},
          "fontWeight": {"value": "bold"},
          "fontSize": {"value": 11}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1)"},
          "text": {
            "signal": "(datum.x1 - datum.x0) > 60 ? datum.state : ''"
          },
          "tooltip": {
            "signal": "{'State': datum.state, 'Primary Schools': datum.schools}"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "tree"},
      "encode": {
        "enter": {
          "font": {"value": "Arial"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fill": {"value": "white"},
          "fontSize": {"value": 10}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1) + 14"},
          "text": {
            "signal": "(datum.x1 - datum.x0) > 60 ? datum.schools : ''"
          }
        }
      }
    }
  ]
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 500,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/completion_trend.csv"
  },
  "transform": [
  {"calculate": "toNumber(datum.year)", "as": "year"}
],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": 0}
        },
        "y": {
          "field": "completion",
          "type": "quantitative",
          "title": "Completion Rate (%)",
          "scale": {"domain": [88, 102]},
          "axis": {"format": ".1f"}
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "title": "Education Level",
          "scale": {
            "domain": ["Primary", "Secondary Lower", "Secondary Upper"],
            "range":["#faf0ca", "#c1dbe8", "#6a4a3a"]
          },
          "legend": {
          "orient": "bottom-right",
          "fillColor": "white",
          "padding": 8,
          "cornerRadius": 6,
          "strokeColor": "#ccc"
        }
      },
      "tooltip": [
        {"field": "year", "type": "ordinal", "title": "Year"},
        {"field": "stage", "type": "nominal", "title": "Level"},
          {
            "field": "completion",
            "type": "quantitative",
            "title": "Completion Rate (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "#e8405a",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {"datum": 100}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "dy": 20,
        "dx": 25,
        "fontSize": 10,
        "color": "#e8405a",
        "fontWeight": "bold"
      },
      "transform": [
        {
          "filter": "datum.year == 2020 && datum.stage == 'Secondary Upper'"
        }
      ],
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "completion",
          "type": "quantitative"
        },
        "text": {"value": "⚠ COVID-19 Impact"}
      }
    }
  ]
}
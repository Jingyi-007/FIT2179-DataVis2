{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 350,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/enrolment_trend.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": 0}
        },
        "y": {
          "field": "students",
          "type": "quantitative",
          "title": "Number of Students",
          "axis": {
    "labelExpr": "datum.value >= 1000000 ? (datum.value / 1000000) + 'M' : datum.value == 0 ? '0' : (datum.value / 1000) + 'K'",
    "tickCount": 8
  }
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "title": "Education Level",
          "scale": {
            "domain": ["Primary", "Secondary", "Post Secondary"],
            "range": ["#fbedb2", "#c1dbe8", "#6a4a3a"]
          }
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "stage", "type": "nominal", "title": "Level"},
          {"field": "students", "type": "quantitative", 
           "title": "Students", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "transform": [
        {"filter": "datum.year == 2022"}
      ],
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "students",
          "type": "quantitative"
        },
        "text": {
          "field": "stage",
          "type": "nominal"
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "scale": {
            "domain": ["Primary", "Secondary", "Post Secondary"],
            "range":["#fbedb2", "#c1dbe8", "#6a4a3a"]
          }
        }
      }
    },
  {
  "transform": [
    {
      "filter": "datum.year == 2020 && datum.stage == 'Post Secondary'"
    }
  ],
  "mark": {
    "type": "text",
    "align": "left",
    "dx": -80,
    "dy": -30,
    "fontSize": 10,
    "fontWeight": "bold",
    "color": "#e8405a"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal"
    },
    "y": {
      "field": "students",
      "type": "quantitative"
    },
    "text": {
      "value": "Dropped due to COVID-19 disruption"
    }
  }
},
{
  "transform": [
    {
      "filter": "datum.year == 2020 && datum.stage == 'Post Secondary'"
    }
  ],
  "mark": {
    "type": "rule",
    "color": "#e8405a",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {"field": "year", "type": "ordinal"},
    "y": {"field": "students", "type": "quantitative"},
    "y2": {"datum": 200000}
  }
}
  ]
}
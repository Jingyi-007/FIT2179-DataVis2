{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Student Enrolment Trend in Malaysia (2017-2022)",
    "fontSize": 16,
    "fontWeight": "bold"
  },
  "width": 600,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/enrolment_trend.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": 0}
        },
        "y": {
          "field": "students",
          "type": "quantitative",
          "title": "Number of Students",
          "axis": {"format": ","}
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "title": "Education Level",
          "scale": {
            "domain": ["Primary", "Secondary", "Post Secondary"],
            "range": ["#43302e", "#c1dbe8", "#fbe29d"]
          }
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "stage", "type": "nominal", "title": "Level"},
          {"field": "students", "type": "quantitative", 
           "title": "Students", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "transform": [
        {"filter": "datum.year == 2022"}
      ],
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "students",
          "type": "quantitative"
        },
        "text": {
          "field": "stage",
          "type": "nominal"
        },
        "color": {
          "field": "stage",
          "type": "nominal",
          "scale": {
            "domain": ["Primary", "Secondary", "Post Secondary"],
            "range": ["#ffffff", "#c1dbe8", "#43302e"]
          }
        }
      }
    }
  ]
}
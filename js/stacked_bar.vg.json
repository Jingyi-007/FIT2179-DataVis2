{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 300,
  "height": 380,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/enrolment_by_state.csv"
  },
  "mark": {"type": "bar", "cornerRadiusEnd": 3},
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": {
        "field": "students",
        "op": "sum",
        "order": "descending"
      }
    },
    "x": {
      "field": "students",
      "type": "quantitative",
      "title": "Number of Students",
      "axis": {"format": ","}
    },
    "color": {
      "field": "stage",
      "type": "nominal",
      "title": "Education Level",
      "scale": {
        "domain": ["Primary", "Secondary", "Post Secondary"],
        "range":["#faf0ca", "#c1dbe8", "#6a4a3a"]
      },
      "legend": {"title": "Education Level"}
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "stage", "type": "nominal", "title": "Level"},
      {"field": "students", "type": "quantitative", 
       "title": "Students", "format": ","}
    ]
  }
}
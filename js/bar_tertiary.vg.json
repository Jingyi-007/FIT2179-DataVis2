{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Public Universities (IPTA) by State (2022)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": 400,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/schools_tertiary.csv"
  },
  "mark": {"type": "bar", "cornerRadiusEnd": 4},
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "schools",
      "type": "quantitative",
      "title": "No. of Universities",
      "axis": {"tickMinStep": 1}
    },
    "color": {
      "field": "schools",
      "type": "quantitative",
      "scale": {"scheme": "greens"},
      "legend": null
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "schools", "type": "quantitative", "title": "No. of Universities"}
    ]
  }
}
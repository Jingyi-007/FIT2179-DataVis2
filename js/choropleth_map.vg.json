{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 900,
  "height": 450,
  "projection": {
    "type": "equalEarth",
    "scale": {"expr": "zoom_level"},
    "translate": {"expr": "[width/2 + x_pan, height/2 + y_pan]"}
  },
  "params": [
    {
      "name": "zoom_level",
      "value": 153,
      "bind": {"input": "range", "min": 100, "max": 600, "step": 10, "name": "Zoom: "}
    },
    {
      "name": "x_pan",
      "value": 0,
      "bind": {"input": "range", "min": -400, "max": 400, "step": 10, "name": "Move Left/Right: "}
    },
    {
      "name": "y_pan",
      "value": 0,
      "bind": {"input": "range", "min": -300, "max": 300, "step": 10, "name": "Move Up/Down: "}
    }
  ],
  "layer": [
    {
      "data": {"sphere": true},
      "mark": {"type": "geoshape", "fill": "#d4eaf7", "stroke": "#aacfe8", "strokeWidth": 0.5}
    },
    {
      "data": {"graticule": {"step": [30, 30]}},
      "mark": {"type": "geoshape", "fill": null, "stroke": "#aacfe8", "strokeWidth": 0.8, "strokeOpacity": 0.5}
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#d0d0d0", "stroke": "white", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/Jingyi-007/FIT2179-DataVis2/main/data/Literacy_Rate_with_id.csv"
            },
            "key": "id",
            "fields": ["Country", "Literacy Rate", "Year"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "color": {
          "field": "Literacy Rate",
          "type": "quantitative",
          "scale": {"scheme": "blues", "domain": [0, 1]},
          "legend": {"title": "Literacy Rate", "format": ".0%", "orient": "bottom-right"}
        },
        "tooltip": [
          {"field": "Country", "type": "nominal", "title": "Country"},
          {"field": "Literacy Rate", "type": "quantitative", "title": "Literacy Rate", "format": ".1%"},
          {"field": "Year", "type": "quantitative", "title": "Year"}
        ]
      }
    },

    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "filter": "indexof([458, 246, 566, 410, 840], datum.id) >= 0"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#FF6B00",
        "strokeWidth": 2.5
      }
    },

    {
      "data": {
        "values": [
          {"longitude": 109.5, "latitude": 4.5,   "label": " Malaysia",   "anchor": "middle", "dy": -10},
          {"longitude": 25.0,  "latitude": 64.0,   "label": " Finland",    "anchor": "middle", "dy": -10},
          {"longitude": 8.0,   "latitude": 9.0,    "label": " Nigeria",    "anchor": "start",  "dy": -8},
          {"longitude": 127.5, "latitude": 36.5,   "label": " South Korea","anchor": "middle", "dy": -10},
          {"longitude": -99.0, "latitude": 38.0,   "label": " USA",        "anchor": "middle", "dy": -10}
        ]
      },
      "projection": {
        "type": "equalEarth",
        "scale": {"expr": "zoom_level"},
        "translate": {"expr": "[width/2 + x_pan, height/2 + y_pan]"}
      },
      "layer": [
        {
          "mark": {
            "type": "circle",
            "color": "#84593d",
            "size": 50,
            "opacity": 0.9
          },
          "encoding": {
            "longitude": {"field": "longitude", "type": "quantitative"},
            "latitude": {"field": "latitude", "type": "quantitative"}
          }
        },
        {
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "black",
            "dy": -12
          },
          "encoding": {
            "longitude": {"field": "longitude", "type": "quantitative"},
            "latitude": {"field": "latitude", "type": "quantitative"},
            "text": {"field": "label", "type": "nominal"}
          }
        },
        {
          "data": {
            "values": [
              {"longitude": 109.5, "latitude": 4.5, "note": "95% literacy rate"}
            ]
          },
          "projection": {
            "type": "equalEarth",
            "scale": {"expr": "zoom_level"},
            "translate": {"expr": "[width/2 + x_pan, height/2 + y_pan]"}
          },
          "layer": [
            {
              "mark": {
                "type": "text",
                "fontSize": 10,
                "fontStyle": "italic",
                "color": "#3c2415",
                "dy": -10,
                "dx": 78,
                "stroke": "#3c2415",
                "strokeWidth": 1.5,
                "strokeOpacity": 0.25
              },
              "encoding": {
                "longitude": {"field": "longitude", "type": "quantitative"},
                "latitude": {"field": "latitude", "type": "quantitative"},
                "text": {"field": "note", "type": "nominal"}
              }
            }
          ]
        }
      ]
    }
  ]
}